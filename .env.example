# X API v2 Bearer Token from a Project App with Pay-per-use credits enabled.
X_BEARER_TOKEN=your_bearer_token_here

# Accounts to monitor, without @. Comma-separated for multiple accounts.
X_USERNAMES=xdevelopers,github

# Backward-compatible single-account setting. Used only if X_USERNAMES is empty.
X_USERNAME=xdevelopers

# Polling interval. Higher values reduce API usage.
POLL_SECONDS=300

# Local state file. Keep this out of git.
STATE_FILE=.twitter-monitor-state.json

# X API user timeline accepts 5-100. Keep low while testing.
MAX_RESULTS=5

# 0 runs forever. Set 1 for a one-shot test.
MAX_POLLS=0

# On first run, save the latest visible post instead of notifying old posts.
SKIP_EXISTING_ON_START=true

# Print notifications without sending webhooks.
DRY_RUN=false

# Logging. Use DEBUG for verbose troubleshooting.
LOG_LEVEL=INFO
LOG_FILE=

# Optional: when empty, notifications are printed to the console only.
DISCORD_WEBHOOK_URL=
DISCORD_USE_EMBED=true
DISCORD_EMBED_COLOR=#f1d400
DISCORD_FOOTER_TEXT=X
DISCORD_FOOTER_ICON_URL=
DISCORD_AUTHOR_NAME=Twitter/X Monitor
DISCORD_AUTHOR_ICON_URL=
DISCORD_USERNAME=
DISCORD_AVATAR_URL=

# Set to false if you want replies included.
EXCLUDE_REPLIES=true

# Set to true to monitor reposts/retweets too.
INCLUDE_REPOSTS=true
